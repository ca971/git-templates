#!/bin/bash
# ╔══════════════════════════════════════════════════════════════╗
# ║  Pre-push hook — Last gate before code leaves your machine   ║
# ║                                                              ║
# ║  Checks (in order):                                          ║
# ║  1. WIP/fixup/squash commits (blocks)                        ║
# ║  2. Lua syntax validation (luajit > luac5.1 > luac)          ║
# ║  3. StyLua formatting (blocks)                               ║
# ║  4. Version consistency (tag push only)                      ║
# ║  5. CHANGELOG entry (tag push only, warning)                 ║
# ║  6. Branch protection (interactive confirmation)             ║
# ║  7. Uncommitted changes warning                              ║
# ║                                                              ║
# ║  Exit codes:                                                 ║
# ║  • 0 = all checks passed                                     ║
# ║  • 1 = blocking issue found — push rejected                  ║
# ╚══════════════════════════════════════════════════════════════╝

set -euo pipefail

# ── Colors ─────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ── Counters ──────────────────────────────────────────────────
errors=0
warnings=0

error() {
  echo -e "${RED}  ✗ $1${NC}"
  errors=$((errors + 1))
}

warn() {
  echo -e "${YELLOW}  ⚠ $1${NC}"
  warnings=$((warnings + 1))
}

ok() {
  echo -e "${GREEN}  ✓ $1${NC}"
}

info() {
  echo -e "${DIM}    $1${NC}"
}

# ── Helper: check if upstream tracking branch exists ──────────
has_upstream() {
  git rev-parse --abbrev-ref '@{upstream}' &> /dev/null
}

# ── Context ───────────────────────────────────────────────────
branch=$(git symbolic-ref --short HEAD 2> /dev/null || echo "detached")
remote="$1"
#url="$2"
# $2 is the remote URL — not used in this hook

# Detect if pushing a tag — save stdin before it's consumed
pushing_tag=false
tag_name=""
push_refs=()
while read -r local_ref local_sha remote_ref remote_sha; do
  push_refs+=("$local_ref $local_sha $remote_ref $remote_sha")
  if echo "$remote_ref" | grep -q '^refs/tags/'; then
    pushing_tag=true
    tag_name="${remote_ref#refs/tags/}"
  fi
done

echo -e "${CYAN}🔍 Pre-push checks...${NC}"
echo -e "${DIM}   Branch: ${branch}  Remote: ${remote}  Tag: ${tag_name:-none}${NC}"

# ── Determine commit range to check ──────────────────────────
# Use upstream if available, otherwise use remote/branch
if has_upstream; then
  commit_range="@{upstream}..HEAD"
elif git rev-parse --verify "${remote}/${branch}" &> /dev/null; then
  commit_range="${remote}/${branch}..HEAD"
else
  # First push ever — check all commits
  commit_range="HEAD"
fi

# ══════════════════════════════════════════════════════════════
# 1. WIP / FIXUP / SQUASH COMMITS (blocks)
# ══════════════════════════════════════════════════════════════

if [ "$commit_range" = "HEAD" ]; then
  wip_commits=$(git log --oneline 2> /dev/null | grep -iE '(^wip |^wip:|fixup!|squash!|amend!)' || true)
else
  wip_commits=$(git log "$commit_range" --oneline 2> /dev/null | grep -iE '(^wip |^wip:|fixup!|squash!|amend!)' || true)
fi

if [ -n "$wip_commits" ]; then
  error "WIP/fixup commits found — squash before pushing:"
  echo "$wip_commits" | while IFS= read -r line; do
    info "$line"
  done
  info "Run: git rebase -i --autosquash"
else
  ok "No WIP/fixup commits"
fi

# ── Detect if repo contains Lua files ────────────────────────
has_lua_files=false
lua_file_count=$(find . -name '*.lua' \
  -not -path './.git/*' \
  -not -path './lua_modules/*' \
  -not -path './local/*' \
  -not -path './.local/*' \
  -not -path './node_modules/*' \
  2> /dev/null | wc -l | tr -d ' ')

if [ "$lua_file_count" -gt 0 ]; then
  has_lua_files=true
fi

# ══════════════════════════════════════════════════════════════
# 2. LUA SYNTAX VALIDATION (blocks — skipped if no Lua files)
# ══════════════════════════════════════════════════════════════

if [ "$has_lua_files" = true ]; then
  LUA_CHECK=""
  LUA_CHECK_NAME=""
  if command -v luajit &> /dev/null; then
    LUA_CHECK="luajit -bl"
    LUA_CHECK_NAME="LuaJIT"
  elif command -v luac5.1 &> /dev/null; then
    LUA_CHECK="luac5.1 -p"
    LUA_CHECK_NAME="luac5.1"
  elif command -v luac &> /dev/null; then
    LUA_CHECK="luac -p"
    LUA_CHECK_NAME="luac"
  fi

  if [ -n "$LUA_CHECK" ]; then
    lua_errors=0
    file_count=0
    while IFS= read -r -d '' f; do
      file_count=$((file_count + 1))
      if ! $LUA_CHECK "$f" &> /dev/null; then
        if [ $lua_errors -eq 0 ]; then
          error "Lua syntax errors (${LUA_CHECK_NAME}):"
        fi
        info "$f"
        $LUA_CHECK "$f" 2>&1 | head -3 | while IFS= read -r err_line; do
          info "  $err_line"
        done
        lua_errors=$((lua_errors + 1))
      fi
    done < <(find . -name '*.lua' \
      -not -path './.git/*' \
      -not -path './lua_modules/*' \
      -not -path './local/*' \
      -not -path './.local/*' \
      -not -path './node_modules/*' \
      -print0 2> /dev/null)

    if [ $lua_errors -eq 0 ]; then
      ok "Lua syntax — ${file_count} files checked (${LUA_CHECK_NAME})"
    fi
  else
    warn "No Lua checker found — skipping syntax check"
    info "Install: brew install luajit"
  fi
else
  ok "No Lua files found — skipping syntax check"
fi

# ══════════════════════════════════════════════════════════════
# 3. STYLUA FORMATTING (blocks — skipped if no lua/ directory)
# ══════════════════════════════════════════════════════════════

if [ -d "lua/" ]; then
  if command -v stylua &> /dev/null; then
    if stylua --check lua/ &> /dev/null; then
      ok "StyLua formatting"
    else
      error "StyLua formatting issues detected"
      stylua --check lua/ 2>&1 | head -10 | while IFS= read -r line; do
        info "$line"
      done
      info "Fix with: stylua lua/"
    fi
  else
    warn "StyLua not installed — skipping format check"
  fi
elif [ "$has_lua_files" = true ]; then
  if command -v stylua &> /dev/null; then
    if stylua --check . &> /dev/null; then
      ok "StyLua formatting"
    else
      error "StyLua formatting issues detected"
      stylua --check . 2>&1 | head -10 | while IFS= read -r line; do
        info "$line"
      done
      info "Fix with: stylua ."
    fi
  else
    warn "StyLua not installed — skipping format check"
  fi
else
  ok "No lua/ directory — skipping StyLua check"
fi

# ══════════════════════════════════════════════════════════════
# 4. VERSION CONSISTENCY (tag push only — blocks)
# ══════════════════════════════════════════════════════════════

if [ "$pushing_tag" = true ]; then
  version_file="lua/core/version.lua"

  if [ -f "$version_file" ]; then
    V_MAJOR=$(grep -E '^\s+major\s*=' "$version_file" | head -1 | grep -oE '[0-9]+')
    V_MINOR=$(grep -E '^\s+minor\s*=' "$version_file" | head -1 | grep -oE '[0-9]+')
    V_PATCH=$(grep -E '^\s+patch\s*=' "$version_file" | head -1 | grep -oE '[0-9]+')

    if [ -n "$V_MAJOR" ] && [ -n "$V_MINOR" ] && [ -n "$V_PATCH" ]; then
      lua_version="${V_MAJOR}.${V_MINOR}.${V_PATCH}"
      expected_tag="v${lua_version}"

      if [ "$tag_name" = "$expected_tag" ]; then
        ok "Tag ${tag_name} matches version.lua (${lua_version})"
      else
        error "Tag ${tag_name} does not match version.lua (${lua_version})"
        info "Update version.lua or use: ./scripts/release.sh ${tag_name#v} \"description\""
      fi
    else
      warn "Could not parse version from ${version_file}"
    fi
  else
    warn "version.lua not found — cannot verify tag consistency"
  fi

  # ── 5. CHANGELOG ENTRY (tag push only — warning) ─────────
  if [ -f "CHANGELOG.md" ]; then
    tag_version="${tag_name#v}"
    if grep -q "\[${tag_version}\]" CHANGELOG.md; then
      ok "CHANGELOG.md contains [${tag_version}]"
    else
      warn "CHANGELOG.md missing [${tag_version}] entry"
      info "Consider updating CHANGELOG.md before release"
    fi
  else
    warn "CHANGELOG.md not found"
  fi
else
  ok "Not a tag push — skipping version/changelog checks"
fi

# ══════════════════════════════════════════════════════════════
# 6. BRANCH PROTECTION (interactive — blocks on refusal)
# ══════════════════════════════════════════════════════════════

protected_branches="main|master|production|release|staging"

if echo "$branch" | grep -qE "^(${protected_branches})$"; then
  # Count commits ahead
  if [ "$commit_range" = "HEAD" ]; then
    ahead=$(git rev-list --count HEAD 2> /dev/null || echo "?")
    ahead_label="${ahead} (initial push)"
  else
    ahead=$(git rev-list --count "$commit_range" 2> /dev/null || echo "?")
    ahead_label="${ahead}"
  fi

  echo ""
  echo -e "${YELLOW}  ⚠ Pushing ${BOLD}${ahead_label}${NC}${YELLOW} commit(s) to protected branch: ${BOLD}${branch}${NC}"

  # Show what's about to be pushed
  echo -e "${DIM}"
  if [ "$commit_range" = "HEAD" ]; then
    git log --oneline 2> /dev/null | head -5 | while IFS= read -r line; do
      echo "    $line"
    done
  else
    git log "$commit_range" --oneline 2> /dev/null | head -5 | while IFS= read -r line; do
      echo "    $line"
    done
  fi
  if [ "$ahead" != "?" ] && [ "$ahead" -gt 5 ] 2> /dev/null; then
    echo "    ... and $((ahead - 5)) more"
  fi
  echo -e "${NC}"

  # Only prompt if stdin is a terminal
  if [ -t 0 ]; then
    exec < /dev/tty
    read -p "   Continue pushing to ${branch}? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      echo -e "${RED}🚫 Push cancelled${NC}"
      exit 1
    fi
  fi
fi

# ══════════════════════════════════════════════════════════════
# 7. UNCOMMITTED CHANGES WARNING (warning only)
# ══════════════════════════════════════════════════════════════

if ! git diff --quiet 2> /dev/null || ! git diff --cached --quiet 2> /dev/null; then
  dirty_count=$(git status --porcelain 2> /dev/null | wc -l | tr -d ' ')
  warn "You have ${dirty_count} uncommitted change(s) in your working tree"
  info "These changes will NOT be included in the push"
else
  ok "Working tree clean"
fi

# ══════════════════════════════════════════════════════════════
# SUMMARY
# ══════════════════════════════════════════════════════════════

echo ""

if [ $errors -gt 0 ]; then
  echo -e "${RED}🚫 ${errors} error(s), ${warnings} warning(s) — push rejected${NC}"
  echo -e "${DIM}   Fix the errors above or use ${NC}${YELLOW}git push --no-verify${NC}${DIM} to bypass${NC}"
  exit 1
fi

if [ $warnings -gt 0 ]; then
  echo -e "${GREEN}✅ Pre-push passed${NC} ${YELLOW}(${warnings} warning(s))${NC}"
else
  echo -e "${GREEN}✅ All pre-push checks passed${NC}"
fi
